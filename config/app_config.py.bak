@dataclass
class MemoryConfig:
    """记忆管理配置"""
    short_term: Dict[str, Any] = None
    medium_term: Dict[str, Any] = None  
    long_term: Dict[str, Any] = None
    
    def __post_init__(self):
        if self.short_term is None:
            self.short_term = {"max_messages": 20, "expire_hours": 24}
        if self.medium_term is None:
            self.medium_term = {"storage_days": 90, "importance_threshold": 5}
        if self.long_term is None:
            self.long_term = {"storage_months": 12, "access_boost": True}

@dataclass
class TestingConfig:
    """测试期配置"""
    phase: str = "testing"  # testing/beta/commercial
    all_features_unlocked: bool = True
    commercial_hints: bool = False
    usage_limits: Dict[str, int] = None
    
    def __post_init__(self):
        if self.usage_limits is None:
            self.usage_limits = {
                "daily_conversations": -1,  # -1表示无限制
                "monthly_users": -1,
                "storage_mb": 512
            }

@dataclass
class SystemConfig:
    """系统运行配置"""
    log_level: str = "INFO"
    debug_mode: bool = False
    backup_interval_hours: int = 24
    health_check_interval: int = 300
    context_monitoring: bool = True

class AppConfig:
    """应用配置管理器"""
    
    def __init__(self, env: str = "development"):
        self.env = env
        self.mongodb = MongoDBConfig()
        self.ernie = ErnieConfig()
        self.wechat = WeChatConfig()
        self.personality = PersonalityConfig()
        self.memory = MemoryConfig()
        self.testing = TestingConfig()
        self.system = SystemConfig()
        
        # 从环境变量加载敏感配置
        self._load_from_env()
        
    def _load_from_env(self):
        """从环境变量加载配置"""
        # MongoDB配置
        if os.getenv("MONGODB_URI"):
            self.mongodb.uri = os.getenv("MONGODB_URI")
        
        # 文心一言配置  
        if os.getenv("ERNIE_API_KEY"):
            self.ernie.api_key = os.getenv("ERNIE_API_KEY")
        if os.getenv("ERNIE_SECRET_KEY"):
            self.ernie.secret_key = os.getenv("ERNIE_SECRET_KEY")
            
        # 微信配置
        if os.getenv("WECHAT_TOKEN"):
            self.wechat.token = os.getenv("WECHAT_TOKEN")
        if os.getenv("WECHAT_APP_ID"):
            self.wechat.app_id = os.getenv("WECHAT_APP_ID")
            
    def get_config_dict(self) -> Dict[str, Any]:
        """获取完整配置字典"""
        return {
            "mongodb": self.mongodb.__dict__,
            "ernie": self.ernie.__dict__,
            "wechat": self.wechat.__dict__,
            "personality": self.personality.__dict__,
            "memory": self.memory.__dict__,
            "testing": self.testing.__dict__,
            "system": self.system.__dict__
        }
        
    def validate_config(self) -> bool:
        """配置验证"""
        required_fields = [
            ("mongodb.uri", self.mongodb.uri),
            ("ernie.api_key", self.ernie.api_key),
            ("wechat.token", self.wechat.token)
        ]
        
        missing = []
        for field_name, field_value in required_fields:
            if not field_value:
                missing.append(field_name)
                
        if missing:
            print(f"配置缺失: {missing}")
            return False
            
        return True

# 全局配置实例
config = AppConfig()

if __name__ == "__main__":
    # 测试配置加载
    print("配置加载测试:")
    print(f"MongoDB URI: {config.mongodb.uri}")
    print(f"文心一言模型: {config.ernie.model}")
    print(f"测试期全功能: {config.testing.all_features_unlocked}")
    print(f"配置验证: {'通过' if config.validate_config() else '失败'}")