#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
减肥搭子配置管理系统
安全配置、模块化接口、环境分离
"""

import os
import json
from typing import Dict, Any
from dataclasses import dataclass

@dataclass
class MongoDBConfig:
    """MongoDB Atlas配置"""
    uri: str = "mongodb+srv://username:password@cluster.mongodb.net/weight_buddy"
    database_name: str = "weight_buddy"
    collections: Dict[str, str] = None
    connection_timeout: int = 5000
    max_pool_size: int = 100
    
    def __post_init__(self):
        if self.collections is None:
            self.collections = {
                "users": "users",
                "conversations": "conversations",
                "weight_records": "weight_records", 
                "goals": "goals",
                "memories": "memories",
                "personalities": "personalities"
            }

@dataclass
class ErnieConfig:
    """文心一言API配置"""
    api_key: str = ""
    secret_key: str = ""
    endpoint: str = "https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat/ernie-3.5-8k"
    model: str = "ernie-3.5-8k"
    max_tokens: int = 2000
    temperature: float = 0.8

@dataclass
class WeChatConfig:
    """微信机器人配置"""
    token: str = ""
    encoding_aes_key: str = ""
    app_id: str = ""
    secret: str = ""
    webhook_url: str = ""

